PORT=3000
DISCORD_CLIENT_ID=your_client_id_here
DISCORD_CLIENT_SECRET=your_client_secret_here
DISCORD_REDIRECT_URI=http://localhost:5173/auth/callback
DATABASE_URL=./data/bot.db
# Used to sign the projectx_session JWT cookie. Generate a strong random value, e.g.
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SESSION_SECRET=your_session_secret_here
FRONTEND_URL=http://localhost:5173
# Shared secret used by the Discord bot when calling /api/bot/* endpoints.
# MUST match BOT_API_KEY in bot/.env. Generate a strong random value, e.g.
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
BOT_API_KEY=your_bot_api_key_here
# Discord user ID(s) of the system owner(s) — grants access to /api/admin/* and
# the dashboard admin panel (block users/guilds). Comma-separated for multiple.
# The owner can never be blocked. Leave empty to disable the admin panel entirely.
OWNER_DISCORD_ID=your_discord_user_id_here
