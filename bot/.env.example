DISCORD_TOKEN=your_bot_token_here
DISCORD_CLIENT_ID=your_client_id_here
DISCORD_CLIENT_SECRET=your_client_secret_here
BACKEND_URL=http://localhost:3000
DATABASE_URL=bot.db
# Shared secret used to authenticate to the backend's /api/bot/* endpoints.
# MUST match BOT_API_KEY in backend/.env. Generate a strong random value, e.g.
#   python -c "import secrets; print(secrets.token_hex(48))"
BOT_API_KEY=your_bot_api_key_here

# --- Social Notifications (all optional) ---
# The social_notify cog skips any platform whose credentials are missing.
# YouTube: only needed to resolve @handles -> UC… channel id and best-effort
# live detection. New-video detection works via RSS without a key.
YOUTUBE_API_KEY=
# Twitch app credentials (https://dev.twitch.tv/console/apps) — client_credentials flow.
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=
# Kick app credentials (https://dev.kick.com) — client_credentials flow.
KICK_CLIENT_ID=
KICK_CLIENT_SECRET=
# Poll interval in seconds (default 180, hard minimum 30).
SOCIAL_POLL_INTERVAL=180

# --- Premium / SKU monetization (all optional) ---
# Maps Discord Premium-App-Subscription SKU IDs to the bot's tiers. The
# premium_sync cog reads the application's entitlements and pushes per-guild
# tiers to the backend. Leave empty to disable SKU sync (owner-set premium in
# the dashboard still works). APPLICATION_ID defaults to DISCORD_CLIENT_ID.
APPLICATION_ID=
SKU_BASIC_ID=
SKU_PRO_ID=
# Entitlement poll interval in seconds (default 300, hard minimum 60).
PREMIUM_POLL_INTERVAL=300
