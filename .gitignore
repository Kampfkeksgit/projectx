# ---- Secrets / Environment ----
# Ignore all env files everywhere, but keep the example templates.
.env
.env.*
!.env.example
.env.production.*

# ---- Databases ----
data/
*.db
*.db-journal
*.db-wal
*.db-shm

# ---- Node ----
node_modules/
dist/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm/

# ---- Python (bot) ----
venv/
.venv/
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/

# ---- Logs / temp ----
*.log
logs/
tmp/
.cache/

# ---- OS / Editor ----
.DS_Store
Thumbs.db
.idea/
*.swp
*.swo

# ---- Local secret helpers ----
.gitbook-token

# ---- Capacitor / Android ----
# Das generierte android/-Projekt wird committet (buildbar), aber seine
# lokalen/Build-Artefakte nicht. Die nested android/.gitignore deckt das
# meiste ab; hier zur Sicherheit die kritischen lokalen Pfade.
frontend/android/local.properties
frontend/android/.gradle/
frontend/android/app/build/
frontend/android/build/
frontend/android/app/release/
frontend/android/.idea/
frontend/android/app/src/main/assets/public/
**/*.keystore
**/*.jks
!debug.keystore
